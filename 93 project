import pyautogui
import webbrowser
import time
print("===== AI Desktop Automation Suite =====")
while True:
    print("\n1. Move Mouse")
    print("2. Mouse Click")
    print("3. Type Text")
    print("4. Screenshot")
    print("5. Open Website")
    print("6. Exit")
    choice = input("Choose: ")
    try:
        if choice == "1":
            x = int(input("X Position: "))
            y = int(input("Y Position: "))
            pyautogui.moveTo(x, y, duration=1)
            print("Mouse moved.")
        elif choice == "2":
            pyautogui.click()
            print("Mouse clicked.")
        elif choice == "3":
            text = input("Enter text: ")
            pyautogui.write(text, interval=0.05)
            print("Typing completed.")
        elif choice == "4":
            name = input("Screenshot filename: ")
            image = pyautogui.screenshot()
            image.save(name + ".png")
            print("Screenshot saved.")
        elif choice == "5":
            url = input("Enter website (example: https://google.com): ")
            webbrowser.open(url)
            print("Website opened.")
        elif choice == "6":
            print("Automation stopped.")
            break
        else:
            print("Invalid option.")
        time.sleep(1)
    except Exception as e:
        print("Error:", e)